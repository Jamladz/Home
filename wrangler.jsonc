{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "react-example",
  "compatibility_date": "2026-05-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "none",
    "html_handling": "drop-trailing-slash"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
